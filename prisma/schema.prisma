datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Subscription {
  id               String    @id @default(cuid())
  email            String    @unique
  birthYear        Int
  lifeExpectancy   Int
  unsubscribeToken String    @unique
  confirmToken     String?   @unique
  confirmedAt      DateTime?
  unsubscribedAt   DateTime?
  lastSentWeek     Int       @default(0)
  lastSentAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([confirmedAt, unsubscribedAt, lastSentAt])
}
